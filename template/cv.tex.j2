\begin{minipage}[t]{0.45\textwidth}
	\vspace{-\baselineskip}

	\vspace{15pt}

		{ \fontsize{16}{20} \textcolor{black}{\textbf{\MakeUppercase{((( personal.name[lang] | e )))}}}}

	\vspace{6pt}

	{\Large ((( personal.title[lang] | e )))}
\end{minipage}
\hfill
\begin{minipage}[t]{0.24\textwidth}
	\vspace{-\baselineskip}
	\vspace{15pt}

	\icon{TelegramPlane}{11}{\href{((( personal.contacts.telegram.url )))}{((( personal.contacts.telegram.handle | e )))}}\\
	\icon{Envelope}{11}{\href{mailto:((( personal.contacts.email )))}{((( personal.contacts.email | e )))}}\\
((* if personal.contacts.phone is defined *))
    \icon{Phone}{11}{((( personal.contacts.phone | e )))}\\
((* endif *))
((* if personal.contacts.location is defined *))
    \icon{MapMarkerAlt}{11}{((( personal.contacts.location[lang] | e )))}\\
((* endif *))
\end{minipage}
\begin{minipage}[t]{0.27\textwidth}
	\vspace{-\baselineskip}
	\vspace{15pt}

    \icon{Github}{11}{\href{((( personal.contacts.github.url )))}{github.com/((( personal.contacts.github.handle | e )))}}\\
((* if personal.contacts.linkedin is defined *))
	\icon{Linkedin}{11}{\href{((( personal.contacts.linkedin.url )))}{((( personal.contacts.linkedin.handle | e )))}}\\
((* endif *))
\end{minipage}

%----------------------------------------------------------------------------------------
%	INTRODUCTION, SKILLS AND TECHNOLOGIES
%----------------------------------------------------------------------------------------

\begin{minipage}[t]{0.45\textwidth}
    \cvsect{((( sections[lang].about )))}
	\vspace{-6pt}

	((( summary[lang] | e )))
\end{minipage}
\hfill
\begin{minipage}[t]{0.51\textwidth}
    \cvsect{((( sections[lang].skills )))}
    \vspace{-6pt}

((* for skill in skills *))
    \begin{minipage}[t]{0.28\textwidth}
        \textbf{((( skill.category[lang] | e ))):}
    \end{minipage}%
    \begin{minipage}[t]{0.70\textwidth}
      ((( skill.tools | e )))
    \end{minipage}
