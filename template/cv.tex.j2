    \vspace{1mm}
((* endif *))

((* endfor *))
\end{minipage}

%----------------------------------------------------------------------------------------
%	EXPERIENCE
%----------------------------------------------------------------------------------------
\cvsect{((( sections[lang].experience )))}
\begin{entrylist}
((* for job in experience *))
((* if job.positions is defined *))
((* set job_idx = loop.index0 *))
((* for pos in job.positions *))
	\entrywork
        {((( pos.period[lang] )))\timelinemark{tl-((( job_idx )))-((( loop.index0 )))}\\\footnotesize{((( pos.duration[lang] )))}}
		{((( pos.role[lang] | e )))}
		{((* if loop.first *))((( job.company | e )))((* endif *))}
		{\vspace{-4pt}
        \begin{itemize}[noitemsep,topsep=2pt,parsep=1pt,partopsep=0pt, leftmargin=0pt]
((* for bullet in pos.bullets[lang] *))
        	\item ((( bullet )))
((* endfor *))
        \end{itemize}
        \vspace{2pt}
        \texttt{((( pos.tech | e )))}}
((* endfor *))
((* for i in range(job.positions|length - 1) *))
\timelinesegment{tl-((( job_idx )))-((( i )))}{tl-((( job_idx )))-((( i + 1 )))}
((* endfor *))
((* for i in range(job.positions|length) *))
\timelinedot{tl-((( job_idx )))-((( i )))}
((* endfor *))
((* else *))
	\entrywork
        {((( job.period[lang] ))) \\\footnotesize{((( job.duration[lang] )))}}
		{((( job.role[lang] | e )))}
		{((( job.company | e )))}
		{\vspace{-4pt}
        \begin{itemize}[noitemsep,topsep=2pt,parsep=1pt,partopsep=0pt, leftmargin=0pt]
((* for bullet in job.bullets[lang] *))
        	\item ((( bullet )))
((* endfor *))
        \end{itemize}
        \vspace{2pt}
        \texttt{((( job.tech | e )))}}
((* endif *))
((* endfor *))
\end{entrylist}

%----------------------------------------------------------------------------------------
%	EDUCATION
%----------------------------------------------------------------------------------------
\vspace{-10pt}
\cvsect{((( sections[lang].education )))}
\begin{entrylist}
((* for edu in education *))
    \entry
        {((( edu.period )))}
((* if edu.cert_url is defined *))
        {((( edu.degree[lang] | e ))) / \href{((( edu.cert_url )))}{((* if lang == "ru" *))Сертификат((* else *))Certificate((* endif *))}}
((* else *))
        {((( edu.degree[lang] | e )))}
((* endif *))
        {((( edu.type[lang] | e )))}
        {((( edu.institution[lang] | e )))}
((* endfor *))
\end{entrylist}

%----------------------------------------------------------------------------------------
%	PROJECTS
%----------------------------------------------------------------------------------------
\vspace{-10pt}
\cvsect{((( sections[lang].projects )))}
\begin{entrylist}
((* for project in projects *))
	\entry
		{((( project.type[lang] | e )))}
		{((( project.name | e )))}
((* if project.url *))
		{\href{((( project.url )))}{((( project.url | replace("https://", "") | e )))}}
((* else *))
		{}
((* endif *))
		{((( project.description[lang] | e )))}
((* endfor *))
\end{entrylist}

